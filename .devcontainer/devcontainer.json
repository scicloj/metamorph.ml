{
	"name": "metamorph.ml",
	"build": {
		"dockerfile": "Dockerfile"

		},


    "features": {
    	"ghcr.io/devcontainers-extra/features/clojure-asdf:2": {},
		"ghcr.io/devcontainers-extra/features/bash-command:1": {},
		"ghcr.io/rocker-org/devcontainer-features/quarto-cli:1": {},
		"ghcr.io/itsmechlark/features/redis-server:1": {},
		"ghcr.io/rocker-org/devcontainer-features/pandoc:1": {},
		"ghcr.io/devcontainer-community/devcontainer-features/astral.sh-uv:1": {},
		"ghcr.io/rocker-org/devcontainer-features/r-apt:0": {}


},
	"customizations": {
		"vscode": {
			"settings": { 
			},
			"extensions": 
			[
				"betterthantomorrow.calva",
				"eamodio.gitlens",
				"zhaouv.vscode-markdown-everywhere",
				"betterthantomorrow.calva-power-tools"
			]
		}
	},

	"remoteUser": "vscode",
	"postCreateCommand": {
		"Rserve": "Rscript -e 'install.packages(\"Rserve\",,\"http://rforge.net\")'",
		"clj deps": "clojure -P -A:dev:exp -Sthreads 1  > /tmp/progress.log 2>&1"


	}
}
